/*
 * lora_credentials.h.example — TEMPLATE (committed; safe, no secrets).
 *
 * The real `lora_credentials.h` is gitignored — it contains the AppKey SECRET and is generated
 * from `firmware/.env`. On a clean clone / in CI that file is absent, so `lora.cpp` falls back to
 * THIS template's PLACEHOLDER values via __has_include — the project still builds (build-check
 * only; placeholder creds cannot join a network).
 *
 * To run on hardware: copy this to `lora_credentials.h` and fill in real OTAA keys (or regenerate
 * it from `firmware/.env`). Never commit the filled-in file.
 */
#ifndef LORA_CREDENTIALS_H
#define LORA_CREDENTIALS_H
#include <stdint.h>
#define LORA_JOINEUI 0x0000000000000000ULL
#define LORA_DEVEUI  0x0000000000000000ULL
static const uint8_t LORA_APPKEY[16] = {0};
#endif /* LORA_CREDENTIALS_H */
